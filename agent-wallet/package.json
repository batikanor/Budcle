{
  "name": "agent-stack-ecosystem-kits",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source example projects integrating the Circle Agent Stack with popular AI agent frameworks.",
  "workspaces": [
    "packages/*",
    "kits/*"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "tsx --test tests/*.test.ts",
    "clean": "bun run --filter '*' clean"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.0"
  }
}
